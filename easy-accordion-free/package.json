{
	"name": "easy-accordion-free",
	"version": "1.0.0",
	"description": "The blocks library for Gutenberg.",
	"author": "ShapedPlugin LLC",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"start:blocks": "wp-scripts start src/blocks/ea-blocks.js --output-path=Blocks/build",
		"start:admin": "wp-scripts start src/admin/ea-dashboard.js --output-path=admin/Dashboard/build",
		"build:blocks": "wp-scripts build src/blocks/ea-blocks.js --output-path=Blocks/build && npm run postbuild",
		"build:admin": "wp-scripts build src/admin/ea-dashboard.js --output-path=admin/Dashboard/build && npm run postbuild:admin",
		"format": "wp-scripts format ./src",
		"build": "npm run build:blocks && npm run build:admin",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"package": "node build-zip.js",
		"release": "npm run build && npm run package",
		"makepot": "php -d memory_limit=3G $(which wp) i18n make-pot . languages/easy-accordion-free.pot --exclude=src",
		"postbuild": "find Blocks/build -name '*-rtl.css' -type f -delete",
		"postbuild:admin": "find admin/Dashboard/build -name '*-rtl.css' -type f -delete"
	},
	"devDependencies": {
		"@wordpress/eslint-plugin": "^22.18.0",
		"@wordpress/scripts": "^30.21.0",
		"archiver": "^7.0.1",
		"prettier": "^3.2.5",
		"webpack": "^5.102.1",
		"webpack-cli": "^6.0.1",
		"wp-scripts": "^0.0.1-security"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.0",
		"@dnd-kit/modifiers": "^9.0.0",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@emotion/styled": "^11.14.1",
		"@hello-pangea/dnd": "^18.0.1",
		"@monaco-editor/react": "^4.7.0",
		"@mui/material": "^7.3.5",
		"@wordpress/data": "^10.32.0",
		"@wordpress/element": "^6.32.0",
		"array-move": "^4.0.0",
		"axios": "^1.7.7",
		"classnames": "^2.5.1",
		"react-hot-toast": "^2.6.0",
		"react-icons": "^5.3.0",
		"react-select": "^5.8.3",
		"react-toggle": "^4.1.3",
		"swiper": "^12.0.3"
	},
	"overrides": {
		"@eslint/eslintrc": "^3.0.0",
		"@wordpress/scripts": {
			"npm-package-json-lint": {
				"ajv": "^6.12.6",
				"ajv-errors": "^1.0.1"
			}
		}
	}
}